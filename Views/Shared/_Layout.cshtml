@using Microsoft.EntityFrameworkCore
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Webstack Infrar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @inject WebstackInfrar.Data.ApplicationDbContext _dbContext
    @{
        var footerSocialLinks = await _dbContext.SocialLinks
            .Where(s => s.IsActive)
            .OrderBy(s => s.SortOrder)
            .ToListAsync();
    }
    <!-- PUBLIC NAVBAR -->
    @if (!User.Identity!.IsAuthenticated)
    {
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background: linear-gradient(135deg, #2D1B69 0%, #6C3FC5 100%); box-shadow: 0 2px 20px rgba(108,63,197,0.3);">
            <div class="container">
                <a class="navbar-brand fw-800" href="/">
                    <span style="color:#fff; font-size:1.4rem; font-weight:800;">⚡ Webstack Infrar</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        <li class="nav-item"><a class="nav-link text-white" href="#products">Products</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="#projects">Projects</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="#team">Team</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="#contact">Contact</a></li>
                        <li class="nav-item">
                            <a class="btn btn-light text-purple fw-600 px-4" href="/Account/Login">
                                <i class="fas fa-sign-in-alt me-1"></i> Login
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <!-- ADMIN NAVBAR -->
    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background:#2D1B69; box-shadow:0 2px 20px rgba(0,0,0,0.3);">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-800 text-white" href="/Admin/Dashboard">⚡ Webstack Infrar</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="adminNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/Dashboard"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/Employees"><i class="fas fa-users me-1"></i>Employees</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/WorkLogs"><i class="fas fa-clock me-1"></i>Work Logs</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/Customers"><i class="fas fa-user-tie me-1"></i>Customers</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/Products"><i class="fas fa-box me-1"></i>Products</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/Projects"><i class="fas fa-project-diagram me-1"></i>Projects</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/Salaries"><i class="fas fa-money-bill me-1"></i>Salaries</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Admin/SocialLinks"><i class="fas fa-share-alt me-1"></i>Social Links</a></li>
                        <li class="nav-item">
                            <form method="post" action="/Account/Logout" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm px-3">
                                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <!-- EMPLOYEE NAVBAR -->
    @if (User.Identity.IsAuthenticated && User.IsInRole("Employee"))
    {
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background:#2D1B69; box-shadow:0 2px 20px rgba(0,0,0,0.3);">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-800 text-white" href="/Employee/Dashboard">⚡ Webstack Infrar</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#empNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="empNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        <li class="nav-item"><a class="nav-link text-white" href="/Employee/Dashboard"><i class="fas fa-home me-1"></i>Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Employee/MyWorkHistory"><i class="fas fa-history me-1"></i>My Logs</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Employee/MySalary"><i class="fas fa-wallet me-1"></i>My Salary</a></li>
                        <li class="nav-item">
                            <form method="post" action="/Account/Logout" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm px-3">
                                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <!-- MAIN CONTENT -->
    <main style="padding-top: @(User.Identity.IsAuthenticated ? "80px" : "76px");">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer style="background:#2D1B69; color:#fff; padding:40px 0 20px;">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-700 mb-3">⚡ Webstack Infrar</h5>
                    <p style="color:#c4b5fd; font-size:0.9rem;">Building modern software solutions for businesses across Bangladesh and beyond.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-600 mb-3">Quick Links</h6>
                    <ul class="list-unstyled" style="color:#c4b5fd; font-size:0.9rem;">
                        <li><a href="#products" class="text-decoration-none" style="color:#c4b5fd;">Our Products</a></li>
                        <li><a href="#projects" class="text-decoration-none" style="color:#c4b5fd;">Projects</a></li>
                        <li><a href="#team" class="text-decoration-none" style="color:#c4b5fd;">Our Team</a></li>
                        <li><a href="/Account/Login" class="text-decoration-none" style="color:#c4b5fd;">Staff Login</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-600 mb-3">Connect With Us</h6>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var link in footerSocialLinks)
                        {
                            <a href="@link.Url" target="_blank" class="btn btn-sm" style="background:#6C3FC5; color:#fff;">
                                @link.Emoji @link.Platform
                            </a>
                        }
                    </div>
                </div>
            </div>
            <hr style="border-color:#6C3FC5; margin-top:30px;" />
            <p class="text-center mb-0" style="color:#c4b5fd; font-size:0.85rem;">
                &copy; @DateTime.Now.Year Webstack Infrar. All rights reserved.
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>