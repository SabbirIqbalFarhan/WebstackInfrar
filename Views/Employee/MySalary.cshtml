@model List<WebstackInfrar.Models.Salary>
@{
    ViewData["Title"] = "My Salary";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Employee/Dashboard" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">
                <i class="fas fa-wallet me-2" style="color:var(--purple-main);"></i>My Salary Records
            </h2>
            <p class="mb-0" style="color:var(--text-muted);">Your salary and payment history</p>
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    @if (Model.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card" style="background:linear-gradient(135deg,#2D1B69,#6C3FC5);">
                    <div class="stat-icon"><i class="fas fa-money-bill"></i></div>
                    <div class="stat-number">৳@Model.Sum(s => s.Amount).ToString("N0")</div>
                    <div class="stat-label">Total Salary</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card" style="background:linear-gradient(135deg,#065F46,#10B981);">
                    <div class="stat-icon"><i class="fas fa-check"></i></div>
                    <div class="stat-number">@Model.Count(s => s.IsPaid)</div>
                    <div class="stat-label">Months Paid</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card" style="background:linear-gradient(135deg,#991B1B,#EF4444);">
                    <div class="stat-icon"><i class="fas fa-exclamation"></i></div>
                    <div class="stat-number">৳@Model.Sum(s => s.Due).ToString("N0")</div>
                    <div class="stat-label">Total Due</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card" style="background:linear-gradient(135deg,#92400E,#F59E0B);">
                    <div class="stat-icon"><i class="fas fa-times"></i></div>
                    <div class="stat-number">@Model.Count(s => !s.IsPaid)</div>
                    <div class="stat-label">Unpaid Months</div>
                </div>
            </div>
        </div>
    }

    <div class="admin-card">
        @if (!Model.Any())
        {
            <div class="text-center py-5" style="color:var(--text-muted);">
                <i class="fas fa-wallet fa-3x mb-3 d-block" style="opacity:0.2;"></i>
                No salary records found.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-purple table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th>Amount</th>
                            <th>Due</th>
                            <th>Status</th>
                            <th>Paid Date</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="fw-600">
                                    @(new DateTime(s.Year, s.Month, 1).ToString("MMMM yyyy"))
                                </td>
                                <td class="fw-600">৳@s.Amount.ToString("N0")</td>
                                <td style="color:#991B1B;">৳@s.Due.ToString("N0")</td>
                                <td>
                                    @if (s.IsPaid)
                                    {
                                        <span class="badge-success-soft">✅ Paid</span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger-soft">⏳ Unpaid</span>
                                    }
                                </td>
                                <td style="font-size:0.9rem;">
                                    @(s.PaidDate.HasValue ? s.PaidDate.Value.ToString("dd MMM yyyy") : "—")
                                </td>
                                <td style="color:var(--text-muted);font-size:0.9rem;">
                                    @(string.IsNullOrEmpty(s.Notes) ? "—" : s.Notes)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>