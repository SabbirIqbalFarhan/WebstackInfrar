@{
    ViewData["Title"] = "Home";
    var products = ViewBag.Products as List<WebstackInfrar.Models.SaasProduct> ?? new();
    var projects = ViewBag.Projects as List<WebstackInfrar.Models.Project> ?? new();
    var employees = ViewBag.Employees as List<WebstackInfrar.Models.ApplicationUser> ?? new();
    var socialLinks = ViewBag.SocialLinks as List<WebstackInfrar.Models.SocialLink> ?? new();
}

<!-- HERO -->
<section class="hero-section">
    <div class="container position-relative" style="z-index:2;">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <div class="mb-3">
                    <span class="badge rounded-pill px-4 py-2" style="background:rgba(255,255,255,0.15); color:#fff; font-size:0.9rem;">
                        🚀 IT Company — Bangladesh
                    </span>
                </div>
                <h1 style="font-size:clamp(2.2rem,5vw,3.8rem); font-weight:800; color:#fff; line-height:1.15;">
                    Building Digital Solutions <span style="color:#c4b5fd;">That Matter</span>
                </h1>
                <p style="color:#e9d5ff; font-size:1.1rem; margin:24px 0 36px; max-width:520px;">
                    Webstack Infrar delivers modern SaaS products, custom software, and IT solutions to help businesses grow in the digital era.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#products" class="btn btn-light fw-700 px-5 py-3 rounded-pill" style="color:#6C3FC5;">
                        <i class="fas fa-box me-2"></i>Our Products
                    </a>
                    <a href="#contact" class="btn fw-700 px-5 py-3 rounded-pill" style="border:2px solid rgba(255,255,255,0.5); color:#fff;">
                        <i class="fas fa-envelope me-2"></i>Contact Us
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                <div style="font-size:12rem; opacity:0.15;">⚡</div>
            </div>
        </div>
    </div>
</section>

<!-- STATS BAR -->
<section style="background:var(--purple-light); padding:40px 0;">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div style="font-size:2rem; font-weight:800; color:var(--purple-main);">@employees.Count(e => e.IsActive)+</div>
                <div style="color:var(--text-muted); font-weight:500;">Team Members</div>
            </div>
            <div class="col-6 col-md-3">
                <div style="font-size:2rem; font-weight:800; color:var(--purple-main);">@projects.Count(p => p.Status == WebstackInfrar.Models.ProjectStatus.Delivered)+</div>
                <div style="color:var(--text-muted); font-weight:500;">Projects Delivered</div>
            </div>
            <div class="col-6 col-md-3">
                <div style="font-size:2rem; font-weight:800; color:var(--purple-main);">@products.Count+</div>
                <div style="color:var(--text-muted); font-weight:500;">SaaS Products</div>
            </div>
            <div class="col-6 col-md-3">
                <div style="font-size:2rem; font-weight:800; color:var(--purple-main);">100%</div>
                <div style="color:var(--text-muted); font-weight:500;">Client Satisfaction</div>
            </div>
        </div>
    </div>
</section>

<!-- SAAS PRODUCTS -->
<section id="products" style="padding:80px 0; background:#fff;">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge-purple px-3 py-2 rounded-pill mb-3 d-inline-block">💼 Our Products</span>
            <h2 class="section-title">SaaS Products</h2>
            <div class="section-divider mx-auto"></div>
            <p class="section-subtitle">Powerful software solutions built for modern businesses</p>
        </div>

        @if (!products.Any())
        {
            <div class="text-center py-5">
                <div style="font-size:4rem;">📦</div>
                <p style="color:var(--text-muted);">Products coming soon. Check back later!</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var p in products)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="product-card h-100">
                            <div class="product-header">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name" style="height:80px; object-fit:contain; margin-bottom:16px;" />
                                }
                                else
                                {
                                    <div style="font-size:3.5rem; margin-bottom:12px;">🖥️</div>
                                }
                                <h4 class="fw-700 mb-1">@p.Name</h4>
                                <div style="font-size:1.6rem; font-weight:800; color:#c4b5fd;">
                                    ৳@p.Price.ToString("N0")
                                </div>
                            </div>
                            <div class="p-4">
                                <p style="color:var(--text-muted); font-size:0.95rem;">@p.Description</p>
                                @if (!string.IsNullOrEmpty(p.Features))
                                {
                                    <ul class="list-unstyled mt-3">
                                        @foreach (var f in p.Features.Split(','))
                                        {
                                            <li class="mb-1">
                                                <i class="fas fa-check-circle me-2" style="color:var(--purple-main);"></i>
                                                @f.Trim()
                                            </li>
                                        }
                                    </ul>
                                }
                                <a href="#contact" class="btn btn-purple w-100 mt-3 py-2">
                                    Get Started <i class="fas fa-arrow-right ms-2"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<!-- PROJECTS -->
<section id="projects" style="padding:80px 0; background:var(--purple-light);">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge-purple px-3 py-2 rounded-pill mb-3 d-inline-block">🚀 Our Work</span>
            <h2 class="section-title">Projects</h2>
            <div class="section-divider mx-auto"></div>
            <p class="section-subtitle">What we have built and what we are building</p>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-pills justify-content-center mb-4" id="projectTabs">
            <li class="nav-item">
                <button class="nav-link active px-4 fw-600" data-bs-toggle="pill" data-bs-target="#delivered" style="background:var(--purple-main);">
                    ✅ Delivered (@projects.Count(x => x.Status == WebstackInfrar.Models.ProjectStatus.Delivered))
                </button>
            </li>
            <li class="nav-item ms-2">
                <button class="nav-link px-4 fw-600" data-bs-toggle="pill" data-bs-target="#ongoing" style="color:var(--purple-main);">
                    🔄 Ongoing (@projects.Count(x => x.Status == WebstackInfrar.Models.ProjectStatus.Ongoing))
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="delivered">
                <div class="row g-4">
                    @foreach (var p in projects.Where(x => x.Status == WebstackInfrar.Models.ProjectStatus.Delivered))
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card card-purple h-100 p-0 overflow-hidden">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" class="card-img-top" style="height:180px; object-fit:cover;" alt="@p.Title" />
                                }
                                else
                                {
                                    <div style="height:140px; background:linear-gradient(135deg,#2D1B69,#6C3FC5); display:flex; align-items:center; justify-content:center; font-size:3rem;">🏆</div>
                                }
                                <div class="card-body p-4">
                                    <span class="badge-success-soft mb-2 d-inline-block">✅ Delivered</span>
                                    <h5 class="fw-700">@p.Title</h5>
                                    <p style="color:var(--text-muted); font-size:0.9rem;">@p.Description</p>
                                    @if (!string.IsNullOrEmpty(p.ClientName))
                                    {
                                        <small style="color:var(--purple-main);"><i class="fas fa-building me-1"></i>@p.ClientName</small>
                                    }
                                    @if (!string.IsNullOrEmpty(p.TechStack))
                                    {
                                        <div class="mt-2">
                                            @foreach (var t in p.TechStack.Split(','))
                                            {
                                                <span class="badge-purple me-1" style="font-size:0.75rem;">@t.Trim()</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    @if (!projects.Any(x => x.Status == WebstackInfrar.Models.ProjectStatus.Delivered))
                    {
                        <div class="col-12 text-center py-5">
                            <div style="font-size:3rem;">🏆</div>
                            <p style="color:var(--text-muted);">Delivered projects will appear here.</p>
                        </div>
                    }
                </div>
            </div>
            <div class="tab-pane fade" id="ongoing">
                <div class="row g-4">
                    @foreach (var p in projects.Where(x => x.Status == WebstackInfrar.Models.ProjectStatus.Ongoing))
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card card-purple h-100 p-0 overflow-hidden">
                                <div style="height:140px; background:linear-gradient(135deg,#6C3FC5,#8B5CF6); display:flex; align-items:center; justify-content:center; font-size:3rem;">🔄</div>
                                <div class="card-body p-4">
                                    <span class="badge-warning-soft mb-2 d-inline-block">🔄 In Progress</span>
                                    <h5 class="fw-700">@p.Title</h5>
                                    <p style="color:var(--text-muted); font-size:0.9rem;">@p.Description</p>
                                    @if (!string.IsNullOrEmpty(p.TechStack))
                                    {
                                        <div class="mt-2">
                                            @foreach (var t in p.TechStack.Split(','))
                                            {
                                                <span class="badge-purple me-1" style="font-size:0.75rem;">@t.Trim()</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    @if (!projects.Any(x => x.Status == WebstackInfrar.Models.ProjectStatus.Ongoing))
                    {
                        <div class="col-12 text-center py-5">
                            <div style="font-size:3rem;">🔄</div>
                            <p style="color:var(--text-muted);">Ongoing projects will appear here.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- TEAM -->
<section id="team" style="padding:80px 0; background:#fff;">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge-purple px-3 py-2 rounded-pill mb-3 d-inline-block">👥 Our People</span>
            <h2 class="section-title">Meet the Team</h2>
            <div class="section-divider mx-auto"></div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-pills justify-content-center mb-4">
            <li class="nav-item">
                <button class="nav-link active px-4 fw-600" data-bs-toggle="pill" data-bs-target="#current" style="background:var(--purple-main);">
                    💼 Current (@employees.Count(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Current))
                </button>
            </li>
            <li class="nav-item ms-2">
                <button class="nav-link px-4 fw-600" data-bs-toggle="pill" data-bs-target="#interns" style="color:var(--purple-main);">
                    🎓 Interns (@employees.Count(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Intern))
                </button>
            </li>
            <li class="nav-item ms-2">
                <button class="nav-link px-4 fw-600" data-bs-toggle="pill" data-bs-target="#alumni" style="color:var(--purple-main);">
                    🏅 Alumni (@employees.Count(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Ex))
                </button>
            </li>
        </ul>

        <div class="tab-content">
            @foreach (var (tabId, type, icon) in new[] { ("current", WebstackInfrar.Models.EmployeeType.Current, "💼"), ("interns", WebstackInfrar.Models.EmployeeType.Intern, "🎓"), ("alumni", WebstackInfrar.Models.EmployeeType.Ex, "🏅") })
            {
                <div class="tab-pane fade @(tabId == "current" ? "show active" : "")" id="@tabId">
                    <div class="row g-4 justify-content-center">
                        @foreach (var emp in employees.Where(e => e.EmployeeType == type))
                        {
                            <div class="col-6 col-md-4 col-lg-3">
                                <div class="team-card">
                                    <div class="team-avatar">
                                        @(emp.FullName.Length > 0 ? emp.FullName[0].ToString().ToUpper() : "?")
                                    </div>
                                    <h6 class="fw-700 mb-1">@emp.FullName</h6>
                                    <p style="color:var(--purple-main); font-size:0.85rem; font-weight:600;">@emp.Designation</p>
                                    <span class="badge-purple" style="font-size:0.75rem;">@icon @type</span>
                                </div>
                            </div>
                        }
                        @if (!employees.Any(e => e.EmployeeType == type))
                        {
                            <div class="col-12 text-center py-4">
                                <p style="color:var(--text-muted);">No @type members to display.</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- SOCIAL LINKS / CONTACT -->
<section id="contact" style="padding:80px 0; background:var(--purple-light);">
    <div class="container text-center">
        <span class="badge-purple px-3 py-2 rounded-pill mb-3 d-inline-block">📱 Connect</span>
        <h2 class="section-title">Get In Touch</h2>
        <div class="section-divider mx-auto"></div>
        <p class="section-subtitle">Reach us on any of our platforms</p>
        <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
            @foreach (var link in socialLinks)
            {
                <a href="@link.Url" target="_blank"
                       class="btn btn-purple px-4 py-3 fw-600"
                       style="border-radius:14px; font-size:1rem;">
                    @link.Emoji @link.Platform
                </a>
            }
        </div>
    </div>
</section>