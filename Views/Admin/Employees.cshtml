@model List<WebstackInfrar.Models.ApplicationUser>
@{
    ViewData["Title"] = "Employees";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">
                <i class="fas fa-users me-2" style="color:var(--purple-main);"></i>Employees
            </h2>
            <p class="mb-0" style="color:var(--text-muted);">Manage all team members</p>
        </div>
        <a href="/Admin/RegisterEmployee" class="btn btn-purple px-4 py-2">
            <i class="fas fa-user-plus me-2"></i>Register Employee
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <ul class="nav nav-pills mb-4 gap-2">
        <li class="nav-item">
            <button class="nav-link active fw-600 px-4" data-bs-toggle="pill" data-bs-target="#current" style="background:var(--purple-main);">
                💼 Current (@Model.Count(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Current))
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-600 px-4" data-bs-toggle="pill" data-bs-target="#interns" style="color:var(--purple-main);">
                🎓 Interns (@Model.Count(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Intern))
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-600 px-4" data-bs-toggle="pill" data-bs-target="#ex" style="color:var(--purple-main);">
                🏅 Ex-Employees (@Model.Count(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Ex))
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- CURRENT -->
        <div class="tab-pane fade show active" id="current">
            <div class="admin-card">
                <div class="table-responsive">
                    <table class="table table-purple table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Designation</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Join Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.Where(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Current))
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:36px;height:36px;border-radius:50%;background:var(--purple-main);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;flex-shrink:0;">
                                                @emp.FullName[0]
                                            </div>
                                            <span class="fw-600">@emp.FullName</span>
                                        </div>
                                    </td>
                                    <td style="color:var(--text-muted);">@emp.Designation</td>
                                    <td style="font-size:0.9rem;">@emp.Email</td>
                                    <td style="font-size:0.9rem;">@(emp.PhoneNumber ?? "—")</td>
                                    <td style="font-size:0.9rem;">@emp.JoinDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (emp.IsActive)
                                        {
                                            <span class="badge-success-soft">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge-danger-soft">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="/Admin/EditEmployee/@emp.Id" class="btn btn-sm btn-outline-purple px-3">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger px-3"
                                                    onclick="confirmDelete('/Admin/DeleteEmployee/@emp.Id', '@emp.FullName')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Current))
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4" style="color:var(--text-muted);">
                                        No current employees found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- INTERNS -->
        <div class="tab-pane fade" id="interns">
            <div class="admin-card">
                <div class="table-responsive">
                    <table class="table table-purple table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Designation</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Join Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.Where(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Intern))
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:36px;height:36px;border-radius:50%;background:var(--purple-main);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;flex-shrink:0;">
                                                @emp.FullName[0]
                                            </div>
                                            <span class="fw-600">@emp.FullName</span>
                                        </div>
                                    </td>
                                    <td style="color:var(--text-muted);">@emp.Designation</td>
                                    <td style="font-size:0.9rem;">@emp.Email</td>
                                    <td style="font-size:0.9rem;">@(emp.PhoneNumber ?? "—")</td>
                                    <td style="font-size:0.9rem;">@emp.JoinDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (emp.IsActive)
                                        {
                                            <span class="badge-success-soft">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge-danger-soft">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="/Admin/EditEmployee/@emp.Id" class="btn btn-sm btn-outline-purple px-3">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger px-3"
                                                    onclick="confirmDelete('/Admin/DeleteEmployee/@emp.Id', '@emp.FullName')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Intern))
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4" style="color:var(--text-muted);">
                                        No interns found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- EX EMPLOYEES -->
        <div class="tab-pane fade" id="ex">
            <div class="admin-card">
                <div class="table-responsive">
                    <table class="table table-purple table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Designation</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Join Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in Model.Where(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Ex))
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:36px;height:36px;border-radius:50%;background:var(--purple-main);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;flex-shrink:0;">
                                                @emp.FullName[0]
                                            </div>
                                            <span class="fw-600">@emp.FullName</span>
                                        </div>
                                    </td>
                                    <td style="color:var(--text-muted);">@emp.Designation</td>
                                    <td style="font-size:0.9rem;">@emp.Email</td>
                                    <td style="font-size:0.9rem;">@(emp.PhoneNumber ?? "—")</td>
                                    <td style="font-size:0.9rem;">@emp.JoinDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (emp.IsActive)
                                        {
                                            <span class="badge-success-soft">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge-danger-soft">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <a href="/Admin/EditEmployee/@emp.Id" class="btn btn-sm btn-outline-purple px-3">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="btn btn-sm btn-danger px-3"
                                                    onclick="confirmDelete('/Admin/DeleteEmployee/@emp.Id', '@emp.FullName')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any(e => e.EmployeeType == WebstackInfrar.Models.EmployeeType.Ex))
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4" style="color:var(--text-muted);">
                                        No ex-employees found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;">
            <div class="modal-body text-center p-5">
                <div style="font-size:3rem;margin-bottom:16px;">⚠️</div>
                <h5 class="fw-700 mb-2">Delete Employee?</h5>
                <p id="deleteMessage" style="color:var(--text-muted);"></p>
                <p class="text-danger small">This will permanently delete all work logs, salaries and permissions for this employee.</p>
                <div class="d-flex gap-3 justify-content-center mt-4">
                    <button class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <form id="deleteForm" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger px-4">Yes, Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(url, name) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteMessage').textContent = 'Are you sure you want to delete ' + name + '?';
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}