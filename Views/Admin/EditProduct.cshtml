@model WebstackInfrar.ViewModels.SaasProductViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Products" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Edit Product</h2>
            <p class="mb-0" style="color:var(--text-muted);">Update product details</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="admin-card">
                <form method="post" asp-action="EditProduct" asp-controller="Admin">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ImageUrl" class="form-label">Image URL</label>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Features" class="form-label"></label>
                            <input asp-for="Features" class="form-control" />
                            <small style="color:var(--text-muted);">Separate features with commas</small>
                        </div>
                        <div class="col-12">
                            <div class="form-check p-3" style="background:var(--purple-light);border-radius:10px;">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label fw-600">
                                    Active (visible on website)
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/Admin/Products" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>