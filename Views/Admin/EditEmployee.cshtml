@model WebstackInfrar.ViewModels.EditEmployeeViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Employees" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Edit Employee</h2>
            <p class="mb-0" style="color:var(--text-muted);">Update employee details and permissions</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="admin-card">
                <form method="post" asp-action="EditEmployee" asp-controller="Admin" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Designation" class="form-label"></label>
                            <input asp-for="Designation" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmployeeType" class="form-label"></label>
                            <select asp-for="EmployeeType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<WebstackInfrar.Models.EmployeeType>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JoinDate" class="form-label"></label>
                            <input asp-for="JoinDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="ProfilePhoto" class="form-label">Profile Photo</label>
                            @if (!string.IsNullOrEmpty(Model.ExistingPhotoUrl))
                            {
                                <div class="mb-2">
                                    <img src="@Model.ExistingPhotoUrl" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--purple-main);" />
                                </div>
                            }
                            <input asp-for="ProfilePhoto" type="file" class="form-control" accept="image/*" />
                            <small style="color:var(--text-muted);">Leave empty to keep current photo</small>
                        </div>
                        <div class="col-12">
                            <div class="form-check p-3" style="background:var(--purple-light);border-radius:10px;">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label fw-600">Active Employee</label>
                            </div>
                        </div>
                    </div>

                    <!-- PERMISSIONS -->
                    <div class="mt-4">
                        <h6 class="fw-700 mb-3" style="color:var(--purple-dark);">
                            <i class="fas fa-shield-alt me-2" style="color:var(--purple-main);"></i>Feature Permissions
                        </h6>
                        <div class="row g-2">
                            @for (int i = 0; i < Model.AvailablePermissions.Count; i++)
                            {
                                <div class="col-md-6">
                                    <div class="form-check p-3" style="background:var(--purple-light);border-radius:10px;">
                                        <input class="form-check-input" type="checkbox"
                                               name="SelectedPermissionIds"
                                               value="@Model.AvailablePermissions[i].Id"
                                               id="perm_@Model.AvailablePermissions[i].Id"
                                        @(Model.AvailablePermissions[i].IsSelected ? "checked" : "") />
                                        <label class="form-check-label" for="perm_@Model.AvailablePermissions[i].Id">
                                            <span class="fw-600" style="color:var(--purple-dark);">@Model.AvailablePermissions[i].FeatureName</span>
                                            <br />
                                            <small style="color:var(--text-muted);">@Model.AvailablePermissions[i].Description</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/Admin/Employees" class="btn btn-outline-secondary px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>