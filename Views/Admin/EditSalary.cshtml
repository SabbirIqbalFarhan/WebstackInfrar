@model WebstackInfrar.ViewModels.SalaryViewModel
@{
    ViewData["Title"] = "Edit Salary";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Salaries" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Edit Salary</h2>
            <p class="mb-0" style="color:var(--text-muted);">Update salary record for @Model.EmployeeName</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="admin-card">
                <form method="post" asp-action="EditSalary" asp-controller="Admin">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Employee</label>
                            <select asp-for="UserId" class="form-select">
                                @foreach (var emp in Model.Employees)
                                {
                                    if (Model.UserId == emp.Id)
                                    {
                                        <option value="@emp.Id" selected>@emp.FullName — @emp.Designation</option>
                                    }
                                    else
                                    {
                                        <option value="@emp.Id">@emp.FullName — @emp.Designation</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Month" class="form-label"></label>
                            <select asp-for="Month" class="form-select">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    var mName = new DateTime(2000, m, 1).ToString("MMMM");
                                    if (Model.Month == m)
                                    {
                                        <option value="@m" selected>@mName</option>
                                    }
                                    else
                                    {
                                        <option value="@m">@mName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Year" class="form-label"></label>
                            <select asp-for="Year" class="form-select">
                                @for (int y = DateTime.Now.Year; y >= 2020; y--)
                                {
                                    if (Model.Year == y)
                                    {
                                        <option value="@y" selected>@y</option>
                                    }
                                    else
                                    {
                                        <option value="@y">@y</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Due" class="form-label"></label>
                            <input asp-for="Due" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PaidDate" class="form-label"></label>
                            <input asp-for="PaidDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check p-3 w-100" style="background:var(--purple-light);border-radius:10px;">
                                <input asp-for="IsPaid" class="form-check-input" type="checkbox" />
                                <label asp-for="IsPaid" class="form-check-label fw-600">Mark as Paid</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/Admin/Salaries" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>