@model WebstackInfrar.ViewModels.RegisterEmployeeViewModel
@{
    ViewData["Title"] = "Register Employee";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Employees" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Register Employee</h2>
            <p class="mb-0" style="color:var(--text-muted);">Add a new team member</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="admin-card">
                <form method="post" asp-action="RegisterEmployee" asp-controller="Admin" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" placeholder="Min 8 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Designation" class="form-label"></label>
                            <input asp-for="Designation" class="form-control" placeholder="e.g. Software Engineer" />
                            <span asp-validation-for="Designation" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmployeeType" class="form-label"></label>
                            <select asp-for="EmployeeType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<WebstackInfrar.Models.EmployeeType>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JoinDate" class="form-label"></label>
                            <input asp-for="JoinDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+880..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" placeholder="Address" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProfilePhoto" class="form-label">Profile Photo</label>
                            <input asp-for="ProfilePhoto" type="file" class="form-control" accept="image/*" />
                            <small style="color:var(--text-muted);">This photo will be visible on the public website</small>
                        </div>
                    </div>

                    <!-- PERMISSIONS -->
                    <div class="mt-4">
                        <h6 class="fw-700 mb-3" style="color:var(--purple-dark);">
                            <i class="fas fa-shield-alt me-2" style="color:var(--purple-main);"></i>Feature Permissions
                        </h6>
                        <div class="row g-2">
                            @for (int i = 0; i < Model.AvailablePermissions.Count; i++)
                            {
                                <div class="col-md-6">
                                    <div class="form-check p-3" style="background:var(--purple-light);border-radius:10px;">
                                        <input type="hidden" name="AvailablePermissions[@i].Id" value="@Model.AvailablePermissions[i].Id" />
                                        <input class="form-check-input" type="checkbox"
                                               name="SelectedPermissionIds"
                                               value="@Model.AvailablePermissions[i].Id"
                                               id="perm_@Model.AvailablePermissions[i].Id"
                                        @(Model.AvailablePermissions[i].IsSelected ? "checked" : "") />
                                        <label class="form-check-label" for="perm_@Model.AvailablePermissions[i].Id">
                                            <span class="fw-600" style="color:var(--purple-dark);">@Model.AvailablePermissions[i].FeatureName</span>
                                            <br />
                                            <small style="color:var(--text-muted);">@Model.AvailablePermissions[i].Description</small>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-user-plus me-2"></i>Register Employee
                        </button>
                        <a href="/Admin/Employees" class="btn btn-outline-secondary px-4 py-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>