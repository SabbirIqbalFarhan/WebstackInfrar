@model WebstackInfrar.ViewModels.ProjectViewModel
@{
    ViewData["Title"] = "Edit Project";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Projects" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Edit Project</h2>
            <p class="mb-0" style="color:var(--text-muted);">Update project details</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="admin-card">
                <form method="post" asp-action="EditProject" asp-controller="Admin">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ClientName" class="form-label"></label>
                            <input asp-for="ClientName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select"
                                    asp-items="Html.GetEnumSelectList<WebstackInfrar.Models.ProjectStatus>()"></select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="TechStack" class="form-label"></label>
                            <input asp-for="TechStack" class="form-control" />
                            <small style="color:var(--text-muted);">Separate technologies with commas</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CompletionDate" class="form-label"></label>
                            <input asp-for="CompletionDate" class="form-control" type="date" />
                        </div>
                        <div class="col-12">
                            <label asp-for="ImageUrl" class="form-label">Image URL</label>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/Admin/Projects" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>