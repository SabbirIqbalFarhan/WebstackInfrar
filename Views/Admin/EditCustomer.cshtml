@model WebstackInfrar.ViewModels.CustomerViewModel
@{
    ViewData["Title"] = "Edit Customer";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Customers" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Edit Customer</h2>
            <p class="mb-0" style="color:var(--text-muted);">Update customer record</p>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="admin-card">
                <form method="post" asp-action="EditCustomer" asp-controller="Admin">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CustomerName" class="form-label"></label>
                            <input asp-for="CustomerName" class="form-control" />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SaasProductId" class="form-label"></label>
                            <select asp-for="SaasProductId" class="form-select">
                                <option value="">— None —</option>
                                @foreach (var p in Model.SaasProducts)
                                {
                                    if (Model.SaasProductId == p.Id)
                                    {
                                        <option value="@p.Id" selected>@p.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProjectId" class="form-label"></label>
                            <select asp-for="ProjectId" class="form-select">
                                <option value="">— None —</option>
                                @foreach (var p in Model.Projects)
                                {
                                    if (Model.ProjectId == p.Id)
                                    {
                                        <option value="@p.Id" selected>@p.Title</option>
                                    }
                                    else
                                    {
                                        <option value="@p.Id">@p.Title</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TotalAmount" class="form-label"></label>
                            <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PaidAmount" class="form-label"></label>
                            <input asp-for="PaidAmount" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PaymentStatus" class="form-label"></label>
                            <select asp-for="PaymentStatus" class="form-select"
                                    asp-items="Html.GetEnumSelectList<WebstackInfrar.Models.PaymentStatus>()"></select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/Admin/Customers" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>