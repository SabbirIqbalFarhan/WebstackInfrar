@model List<WebstackInfrar.Models.CustomerRecord>
@{
    ViewData["Title"] = "Customers";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">
                <i class="fas fa-user-tie me-2" style="color:var(--purple-main);"></i>Customers
            </h2>
            <p class="mb-0" style="color:var(--text-muted);">Manage customer records and payments</p>
        </div>
        <a href="/Admin/CreateCustomer" class="btn btn-purple px-4 py-2">
            <i class="fas fa-plus me-2"></i>Add Customer
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="admin-card">
        <div class="table-responsive">
            <table class="table table-purple table-hover mb-0">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th>Product / Project</th>
                        <th>Total</th>
                        <th>Paid</th>
                        <th>Due</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-600">@c.CustomerName</div>
                                <small style="color:var(--text-muted);">@c.Email</small>
                            </td>
                            <td style="font-size:0.9rem;">@(string.IsNullOrEmpty(c.Phone) ? "—" : c.Phone)</td>
                            <td style="font-size:0.9rem;">
                                @if (c.SaasProduct != null)
                                {
                                    <span class="badge-purple">@c.SaasProduct.Name</span>
                                }
                                else if (c.Project != null)
                                {
                                    <span class="badge-warning-soft">@c.Project.Title</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);">—</span>
                                }
                            </td>
                            <td class="fw-600">৳@c.TotalAmount.ToString("N0")</td>
                            <td style="color:#065F46;">৳@c.PaidAmount.ToString("N0")</td>
                            <td style="color:#991B1B;">৳@c.DueAmount.ToString("N0")</td>
                            <td>
                                @if (c.PaymentStatus == WebstackInfrar.Models.PaymentStatus.Paid)
                                {
                                    <span class="badge-success-soft">✅ Paid</span>
                                }
                                else if (c.PaymentStatus == WebstackInfrar.Models.PaymentStatus.Partial)
                                {
                                    <span class="badge-warning-soft">⚡ Partial</span>
                                }
                                else
                                {
                                    <span class="badge-danger-soft">⏳ Pending</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="/Admin/EditCustomer/@c.Id" class="btn btn-sm btn-outline-purple px-3">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button class="btn btn-sm btn-danger px-3"
                                            onclick="confirmDelete('/Admin/DeleteCustomer/@c.Id', '@c.CustomerName')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5" style="color:var(--text-muted);">
                                <div style="font-size:3rem;">👤</div>
                                No customer records yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;">
            <div class="modal-body text-center p-5">
                <div style="font-size:3rem;margin-bottom:16px;">⚠️</div>
                <h5 class="fw-700 mb-2">Delete Customer?</h5>
                <p id="deleteMessage" style="color:var(--text-muted);"></p>
                <p class="text-danger small">This will permanently delete this customer record.</p>
                <div class="d-flex gap-3 justify-content-center mt-4">
                    <button class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <form id="deleteForm" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger px-4">Yes, Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(url, name) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteMessage').textContent = 'Are you sure you want to delete ' + name + '?';
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}