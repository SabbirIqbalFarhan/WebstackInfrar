@model WebstackInfrar.ViewModels.SocialLinkViewModel
@{
    ViewData["Title"] = "Add Social Link";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/SocialLinks" class="btn btn-outline-purple btn-sm px-3">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <h2 class="fw-800 mb-0" style="color:var(--purple-dark);">Add Social Link</h2>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="admin-card">
                <form method="post" asp-action="CreateSocialLink" asp-controller="Admin">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Platform" class="form-label"></label>
                            <input asp-for="Platform" class="form-control" placeholder="e.g. Facebook Page" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Emoji" class="form-label"></label>
                            <input asp-for="Emoji" class="form-control" placeholder="🔵" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Url" class="form-label"></label>
                            <input asp-for="Url" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="Url" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SortOrder" class="form-label"></label>
                            <input asp-for="SortOrder" class="form-control" type="number" placeholder="1" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check p-3 w-100" style="background:var(--purple-light);border-radius:10px;">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="IsActive" class="form-check-label fw-600">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-purple px-5 py-2">
                            <i class="fas fa-save me-2"></i>Save
                        </button>
                        <a href="/Admin/SocialLinks" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>